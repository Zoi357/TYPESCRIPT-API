{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "commonjs",
    "target": "ES2020",
    
    "types": ["node"], 

    "lib": ["ES2020"],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "esModuleInterop": true,
    
    "verbatimModuleSyntax": false, 
    "isolatedModules": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": "./src",
    "paths": {
      "_helpers/*": ["_helpers/*"],
      "_middleware/*":["_middleware/*"],
      "_users/*":["_users/*"]
    }
  },
  "include":["src/**/*"],
  "exclude": ["node_modules", "dist"]
}